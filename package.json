{
	"name": "@ace-code/shast",
	"version": "0.1.0",
	"publishConfig": {
		"access": "public"
	},
	"description": "Semantic HTML abstract syntax tree with structurally coupled, scoped CSS — validated at compile time and runtime",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
    "test": "tsc --noEmit && node --import=tsx/esm --test",
		"test:watch": "node --import=tsx/esm --test --watch"
	},
	"keywords": [
		"html",
		"css",
		"ast",
		"semantic",
		"typescript",
		"type-safe",
		"scoped-css",
		"components",
		"validation"
	],
	"author": "Sagi Carmel (https://github.com/AceCodePt)",
	"license": "MIT",
	"packageManager": "pnpm@10.33.3",
	"devDependencies": {
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^25.9.1",
		"tsx": "^4.22.4"
	},
	"dependencies": {
		"typescript": "^6.0.3"
	}
}
